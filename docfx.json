{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": [ "CompassEx/*.csproj" ],
          "exclude": [ "**/bin/**", "**/obj/**" ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "dest":"_site",
     "warningsAsErrors": false,
    "content": [
      {
        "files": [
          "toc.yml",
          "index.md",
          "*.md",
          "api/**/*.yml",
          "api/toc.yml"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default", "modern",
      "templates"
    ],
    "globalMetadata": {
      "_appName": "CompassEx 罗盘算法类库",
      "_appTitle": "CompassEx API文档",
      "_enableSearch": false, 
      "_appLogoPath": "",
      "pdf": true
    }
  }
}
